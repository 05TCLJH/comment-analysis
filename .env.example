# 采集阶段配置示例
# USER_AGENT=
# PROXY=

# 存储阶段配置示例
DATABASE_URL=sqlite:///data/comment_analysis.db
STORAGE_BACKEND=sqlite

# 运行阶段配置示例
# LOG_LEVEL=INFO

# MediaCrawler Bridge（贴吧 / 知乎 / 微博）
# 默认使用 vendor/MediaCrawler 子模块；可覆盖为外部路径：
# MEDIACRAWLER_HOME=D:/MediaCrawler
# MEDIACRAWLER_UV=uv
# MEDIACRAWLER_LAUNCHER=D:/comment-analysis/scripts/run_mediacrawler.py
MEDIACRAWLER_LOGIN_TYPE=qrcode
# MEDIACRAWLER_COOKIES_TIEBA=
# MEDIACRAWLER_COOKIES_ZHIHU=
# MEDIACRAWLER_COOKIES_WEIBO=
MEDIACRAWLER_ENABLE_SUB_COMMENTS=false
MEDIACRAWLER_MAX_SLEEP_SEC=2
# MEDIACRAWLER_TIMEOUT_SECONDS=3600
# MEDIACRAWLER_MAX_COMMENTS_PER_NOTE=10
